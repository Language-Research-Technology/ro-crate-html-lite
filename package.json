{
  "name": "ro-crate-html-lite",
  "type": "module",
  "version": "0.0.8",
  "description": "A tool to create static HTML-only ro-crate-preview-html files for an RO-Crate",
  "main": "index.js",
  "bin": {
    "roc-html": "roc-html.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Language-Research-Technology/ro-crate-html-lite"
  },
  "scripts": {
    "test": "mocha",
    "visualize": "node test/test-bounding-box.js",
    "format": "prettier --write template.html",
    "build": "node precompile.js template.html > template.js"
  },
  "author": "Peter Sefton",
  "contributors": [
    {
      "name": "Alvin Sebastian"
    },
    {
      "name": "Ben Foley"
    },
    {
      "name": "River Tae Smith"
    },
    {
      "name": "Moises Sacal Bonequi"
    }
  ],
  "license": "GPL-3.0",
  "dependencies": {
    "commander": "^12.1.0",
    "markdown-it": "^14.1.1",
    "nunjucks": "^3.2.4",
    "ro-crate": "^3.7.2"
  },
  "devDependencies": {
    "mocha": "^11.7.5",
    "prettier": "^3.6.2",
    "prettier-plugin-jinja-template": "^2.1.0"
  },
  "files": [
    "index.js",
    "roc-html.js",
    "template.html",
    "template.js",
    "lib"
  ],
  "engines": {
    "node": ">=20"
  }
}
